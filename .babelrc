{
    "plugins": [
        [
            "babel-plugin-transform-react-jsx",
            {
                "runtime": "automatic",
                "importSource": "preact"
            }
        ],
        [
            "babel-plugin-htm",
            {
                "tag": "htm",
                "pragma": "h",
                "pragmaFrag": "Fragment"
            }
        ]
    ]
}
